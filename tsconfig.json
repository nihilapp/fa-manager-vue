{
  "extends": "./.nuxt/tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@src/*": [
        "src/*"
      ],
      "@app/*": [
        "src/app/*"
      ],
      "@server/*": [
        "src/server/*"
      ]
    }
  },
  "include": [
    "src/app/types/manual-app-imports.d.ts",
    "src/server/types/manual-server-imports.d.ts",
    ".nuxt/nuxt.d.ts",
    "nuxt.config.ts",
    "src/**/*"
  ]
}
