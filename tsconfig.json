{
  "extends": "./.nuxt/tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "#imports": [
        ".nuxt/imports"
      ],
      "h3": [
        "node_modules/.pnpm/h3@1.15.7/node_modules/h3"
      ],
      "@src/*": [
        "src/*"
      ],
      "@app/*": [
        "src/app/*"
      ],
      "@server/*": [
        "src/server/*"
      ]
    }
  },
  "include": [
    ".nuxt/imports.d.ts",
    ".nuxt/nuxt.d.ts",
    ".nuxt/types/imports.d.ts",
    ".nuxt/types/nitro-imports.d.ts",
    "nuxt.config.ts",
    "src/**/*",
    "**/*.ts",
    "**/*.vue"
  ]
}
